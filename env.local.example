# .env.local.example
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE
# ===========================================
# Get these from: Supabase Dashboard > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# SITE CONFIG
# ===========================================

NEXT_PUBLIC_SITE_URL=https://nycedays.com
# Use http://localhost:3000 for local development

# ===========================================
# ADOBE FONTS (TYPEKIT)
# ===========================================
# Get this from: Adobe Fonts > Web Projects

NEXT_PUBLIC_TYPEKIT_ID=abc1def

# ===========================================
# E-COMMERCE (Choose One)
# ===========================================

# Option 1: Snipcart
NEXT_PUBLIC_SNIPCART_API_KEY=your-snipcart-public-api-key

# Option 2: Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# Use pk_test_ and sk_test_ for development

# ===========================================
# EMAIL (Contact Form Notifications)
# ===========================================
# Using Resend (https://resend.com)

RESEND_API_KEY=re_...
CONTACT_EMAIL=hello@nycedays.com

# ===========================================
# ANALYTICS (Optional)
# ===========================================

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Or Plausible
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=nycedays.com

# ===========================================
# CLOUDFLARE R2 (Video CDN)
# ===========================================

NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://videos.nycedays.com

# ===========================================
# DEVELOPMENT
# ===========================================

# Set to 'development' or 'production'
NODE_ENV=development
